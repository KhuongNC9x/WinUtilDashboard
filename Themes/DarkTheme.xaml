<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Dark Theme Colors -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#9E9E9E"/>

    <SolidColorBrush x:Key="HeaderBrush" Color="#0D0D0D"/>
    <SolidColorBrush x:Key="HeaderTextBrush" Color="White"/>

    <SolidColorBrush x:Key="InputBrush" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#3E3E3E"/>

    <SolidColorBrush x:Key="PrimaryBrush" Color="#0078D4"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#E74856"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#10893E"/>

    <SolidColorBrush x:Key="LogBrush" Color="#0D0D0D"/>
    <SolidColorBrush x:Key="LogTextBrush" Color="#CCCCCC"/>

    <!-- Accent colors for system monitor (brighter for dark theme) -->
    <SolidColorBrush x:Key="AccentGreenBrush" Color="#4EC9B0"/>
    <SolidColorBrush x:Key="AccentYellowBrush" Color="#DCDCAA"/>
    <SolidColorBrush x:Key="AccentOrangeBrush" Color="#F48771"/>
    <SolidColorBrush x:Key="AccentBlueBrush" Color="#9CDCFE"/>
</ResourceDictionary>