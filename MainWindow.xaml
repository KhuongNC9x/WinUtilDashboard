<Window x:Class="WinUtilDashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Windows Utility Dashboard" Height="850" Width="1400"
        WindowStartupLocation="CenterScreen" 
        Background="{DynamicResource BackgroundBrush}"
        Icon="/computer.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Ribbon -->
            <RowDefinition Height="*"/>
            <!-- Main Content -->
            <RowDefinition Height="Auto"/>
            <!-- Log (collapsible) -->
        </Grid.RowDefinitions>

        <!-- HEADER với System Monitor -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBrush}" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="🛠️ Windows Utility Dashboard" 
                           Foreground="{DynamicResource HeaderTextBrush}"
                           FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Border Background="#107C10" CornerRadius="4" Padding="12,6" Margin="8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💻" FontSize="16" Margin="0,0,8,0"/>
                            <StackPanel>
                                <TextBlock Text="CPU" Foreground="White" FontSize="10" Opacity="0.8"/>
                                <TextBlock Text="{Binding CpuDisplay}" Foreground="White" FontSize="14" FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="#0078D4" CornerRadius="4" Padding="12,6" Margin="8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾" FontSize="16" Margin="0,0,8,0"/>
                            <StackPanel>
                                <TextBlock Text="RAM" Foreground="White" FontSize="10" Opacity="0.8"/>
                                <TextBlock Text="{Binding RamDisplay}" Foreground="White" FontSize="14" FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="#D83B01" CornerRadius="4" Padding="12,6" Margin="8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🌡️" FontSize="16" Margin="0,0,8,0"/>
                            <StackPanel>
                                <TextBlock Text="Temp" Foreground="White" FontSize="10" Opacity="0.8"/>
                                <TextBlock Text="{Binding TempDisplay}" Foreground="White" FontSize="14" FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="#107C10" CornerRadius="4" Padding="12,6" Margin="8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💿" FontSize="16" Margin="0,0,8,0"/>
                            <StackPanel>
                                <TextBlock Text="Disk C:" Foreground="White" FontSize="10" Opacity="0.8"/>
                                <TextBlock Text="{Binding DiskDisplay}" Foreground="White" FontSize="14" FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!--
                    Theme toggle: IsChecked is bound two-way to IsDarkMode on the ViewModel.
                    The VM's setter calls ThemeManager.ApplyTheme, so no code-behind needed.
                -->
                <ToggleButton Grid.Column="2" 
                              Width="100" Height="32"
                              IsChecked="{Binding IsDarkMode, Mode=TwoWay}"
                              Content="{Binding DarkModeLabel}"
                              FontSize="13"
                              Background="{DynamicResource PrimaryBrush}" 
                              Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- RIBBON MENU -->
        <Border Grid.Row="1" Background="{DynamicResource InputBrush}" 
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal" Margin="8,4">

                    <Button Style="{StaticResource RibbonButton}" Command="{Binding CheckWindowsUpdateCommand}">
                        <StackPanel>
                            <TextBlock Text="🔄" FontSize="28" HorizontalAlignment="Center"/>
                            <TextBlock Text="Check Update" FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            <TextBlock Text="" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource RibbonButton}" Command="{Binding DisableWindowsUpdateCommand}">
                        <StackPanel>
                            <TextBlock Text="⏸️" FontSize="28" HorizontalAlignment="Center"/>
                            <TextBlock Text="Disable Update" FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            <TextBlock Text="" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource RibbonButton}" Command="{Binding EnableWindowsUpdateCommand}">
                        <StackPanel>
                            <TextBlock Text="▶️" FontSize="28" HorizontalAlignment="Center"/>
                            <TextBlock Text="Enable Update" FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            <TextBlock Text="" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Separator Width="1" Background="{DynamicResource BorderBrush}" Margin="8,8"/>

                    <Button Style="{StaticResource RibbonButton}" Command="{Binding QuickCleanCommand}">
                        <StackPanel>
                            <TextBlock Text="🧹" FontSize="28" HorizontalAlignment="Center"/>
                            <TextBlock Text="Quick Clean" FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            <TextBlock Text="" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource RibbonButton}" Command="{Binding ScanFoldersCommand}">
                        <StackPanel>
                            <TextBlock Text="📁" FontSize="28" HorizontalAlignment="Center"/>
                            <TextBlock Text="Scan Folders" FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            <TextBlock Text="" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Separator Width="1" Background="{DynamicResource BorderBrush}" Margin="8,8"/>

                    <Button Style="{StaticResource RibbonButton}" Command="{Binding ShowProcessesCommand}">
                        <StackPanel>
                            <TextBlock Text="⚙️" FontSize="28" HorizontalAlignment="Center"/>
                            <TextBlock Text="Process Manager" FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            <TextBlock Text="" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource RibbonButton}" Command="{Binding ShowHardwareInfoCommand}">
                        <StackPanel>
                            <TextBlock Text="💻" FontSize="28" HorizontalAlignment="Center"/>
                            <TextBlock Text="Hardware Info" FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            <TextBlock Text="" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Separator Width="1" Background="{DynamicResource BorderBrush}" Margin="8,8"/>

                    <Button Style="{StaticResource RibbonButton}" Command="{Binding ExportReportCommand}">
                        <StackPanel>
                            <TextBlock Text="📄" FontSize="28" HorizontalAlignment="Center"/>
                            <TextBlock Text="Export Report" FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            <TextBlock Text="" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Separator Width="1" Background="{DynamicResource BorderBrush}" Margin="8,8"/>

                    <Button Style="{StaticResource RibbonButton}" Command="{Binding ShowStartupManagerCommand}">
                        <StackPanel>
                            <TextBlock Text="🚀" FontSize="28" HorizontalAlignment="Center"/>
                            <TextBlock Text="Startup Apps" FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            <TextBlock Text="" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Separator Width="1" Background="{DynamicResource BorderBrush}" Margin="8,8"/>

                    <!-- Cancel button: only enabled during long-running operations -->
                    <Button Style="{StaticResource RibbonButton}" 
                            Command="{Binding CancelCurrentOperationCommand}"
                            IsEnabled="{Binding IsBusy}">
                        <StackPanel>
                            <TextBlock Text="⏹️" FontSize="28" HorizontalAlignment="Center"/>
                            <TextBlock Text="Cancel" FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            <TextBlock Text="" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- MAIN CONTENT: Sidebar + Dashboard -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <!-- Sidebar -->
                <ColumnDefinition Width="*"/>
                <!-- Main Dashboard -->
                <ColumnDefinition Width="280"/>
                <!-- Notifications -->
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR: Quick Actions -->
            <Border Grid.Column="0" Background="{DynamicResource InputBrush}" 
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">
                        <TextBlock Text="⚡ Quick Actions" FontWeight="Bold" FontSize="14" 
                                   Margin="8,8,8,12" Foreground="{DynamicResource ForegroundBrush}"/>

                        <Button Style="{StaticResource QuickActionButton}" Command="{Binding DisableWindowsUpdateCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⏸️" FontSize="18" Margin="0,0,12,0"/>
                                <TextBlock Text="Turn off Update" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource QuickActionButton}" Command="{Binding QuickCleanCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🧹" FontSize="18" Margin="0,0,12,0"/>
                                <TextBlock Text="Clean Temp" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource QuickActionButton}" Command="{Binding RefreshProcessCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔄" FontSize="18" Margin="0,0,12,0"/>
                                <TextBlock Text="Refresh Process" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource QuickActionButton}" Command="{Binding ScanFoldersCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📁" FontSize="18" Margin="0,0,12,0"/>
                                <TextBlock Text="Scan Folder" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Separator Margin="4,12"/>

                        <Button Style="{StaticResource QuickActionButton}" Command="{Binding OpenLogsFolderCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📋" FontSize="18" Margin="0,0,12,0"/>
                                <TextBlock Text="Open Logs Folder" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Separator Margin="4,12"/>

                        <TextBlock Text="📊 System Stats" FontWeight="Bold" FontSize="14" 
                                   Margin="8,8,8,12" Foreground="{DynamicResource ForegroundBrush}"/>

                        <Border Style="{StaticResource DashboardCard}" Padding="12" Margin="4">
                            <StackPanel>
                                <TextBlock Text="Uptime" FontSize="11" Opacity="0.7" 
                                           Foreground="{DynamicResource ForegroundBrush}"/>
                                <TextBlock Text="{Binding UptimeDisplay}" FontSize="16" FontWeight="Bold"
                                           Foreground="{DynamicResource ForegroundBrush}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource DashboardCard}" Padding="12" Margin="4">
                            <StackPanel>
                                <TextBlock Text="Total RAM" FontSize="11" Opacity="0.7"
                                           Foreground="{DynamicResource ForegroundBrush}"/>
                                <TextBlock Text="{Binding TotalRamDisplay}" FontSize="16" FontWeight="Bold"
                                           Foreground="{DynamicResource ForegroundBrush}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- DASHBOARD CARDS -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <UniformGrid Columns="2" Margin="16">

                    <!-- Card 1: CPU -->
                    <Border Style="{StaticResource DashboardCard}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="💻" FontSize="32" Margin="0,0,12,0"/>
                                <StackPanel>
                                    <TextBlock Text="CPU Usage" FontSize="16" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                    <TextBlock Text="Processor load" FontSize="11" Opacity="0.6"
                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Grid.Row="1" Text="{Binding CpuDisplay}" 
                                       FontSize="48" FontWeight="Bold" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="#107C10"/>
                            <ProgressBar Grid.Row="2" Height="8" 
                                         Minimum="0" Maximum="100" Value="{Binding CpuPercent}"/>
                        </Grid>
                    </Border>

                    <!-- Card 2: RAM -->
                    <Border Style="{StaticResource DashboardCard}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="💾" FontSize="32" Margin="0,0,12,0"/>
                                <StackPanel>
                                    <TextBlock Text="RAM Usage" FontSize="16" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                    <TextBlock Text="Memory consumption" FontSize="11" Opacity="0.6"
                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{Binding RamDisplay}" 
                                           FontSize="48" FontWeight="Bold" 
                                           HorizontalAlignment="Center"
                                           Foreground="#0078D4"/>
                                <TextBlock Text="{Binding RamDetails}" 
                                           FontSize="14" HorizontalAlignment="Center"
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                            </StackPanel>
                            <ProgressBar Grid.Row="2" Height="8" 
                                         Minimum="0" Maximum="100" Value="{Binding RamPercent}"/>
                        </Grid>
                    </Border>

                    <!-- Card 3: Temperature -->
                    <Border Style="{StaticResource DashboardCard}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="🌡️" FontSize="32" Margin="0,0,12,0"/>
                                <StackPanel>
                                    <TextBlock Text="Temperature" FontSize="16" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                    <TextBlock Text="CPU thermal" FontSize="11" Opacity="0.6"
                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Grid.Row="1" Text="{Binding TempDisplay}" 
                                       FontSize="48" FontWeight="Bold" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="#D83B01"/>
                            <TextBlock Grid.Row="2" Text="Normal: &lt; 70°C" FontSize="12" 
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                        </Grid>
                    </Border>

                    <!-- Card 4: Disk -->
                    <Border Style="{StaticResource DashboardCard}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="💿" FontSize="32" Margin="0,0,12,0"/>
                                <StackPanel>
                                    <TextBlock Text="Disk C: Free" FontSize="16" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                    <TextBlock Text="Available space" FontSize="11" Opacity="0.6"
                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DiskDisplay}" 
                                           FontSize="48" FontWeight="Bold" 
                                           HorizontalAlignment="Center"
                                           Foreground="#107C10"/>
                                <TextBlock Text="{Binding DiskPercentDisplay}" 
                                           FontSize="14" HorizontalAlignment="Center"
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                            </StackPanel>
                            <ProgressBar Grid.Row="2" Height="8" 
                                         Minimum="0" Maximum="100" Value="{Binding DiskFreePercent}"/>
                        </Grid>
                    </Border>

                </UniformGrid>
            </ScrollViewer>

            <!-- NOTIFICATION CENTER -->
            <Border Grid.Column="2" Background="{DynamicResource InputBrush}" 
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="12,12,12,8">
                        <TextBlock Text="🔔" FontSize="18" Margin="0,0,8,0"/>
                        <TextBlock Text="Notifications" FontWeight="Bold" FontSize="14" 
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource ForegroundBrush}"/>
                        <TextBlock Text="{Binding AlertCount, StringFormat='({0})'}" FontSize="12" 
                                   VerticalAlignment="Center" Margin="6,0,0,0"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Alerts}" Margin="8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource BackgroundBrush}" 
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1" CornerRadius="4" 
                                            Padding="10" Margin="4,4,4,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Icon}" 
                                                       FontSize="20" Margin="0,0,10,0"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Message}" TextWrapping="Wrap"
                                                           Foreground="{DynamicResource ForegroundBrush}"/>
                                                <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}" 
                                                           FontSize="10" Opacity="0.6" Margin="0,4,0,0"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Button Grid.Row="2" Content="Clear All" Height="36" Margin="8"
                            Command="{Binding ClearAlertsCommand}"
                            Background="{DynamicResource BackgroundBrush}"
                            Foreground="{DynamicResource ForegroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- LOG OUTPUT (Collapsible) -->
        <Expander Grid.Row="3" Header="📝 Output / Log" IsExpanded="False"
                  Background="{DynamicResource InputBrush}"
                  Foreground="{DynamicResource ForegroundBrush}"
                  BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid Height="250">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Button Grid.Row="0" Content="Xóa log" Style="{StaticResource ActionButton}"
                        HorizontalAlignment="Right" Width="80" Margin="8,4" 
                        Command="{Binding ClearLogCommand}"/>
                <!--
                    Auto-scroll to bottom on every LogText update.
                    VerticalScrollBarVisibility must be "Auto" for scrolling to work;
                    the code-behind hook (TextChanged -> ScrollToEnd) lives in MainWindow.xaml.cs.
                -->
                <TextBox Grid.Row="1" Text="{Binding LogText, Mode=OneWay}" 
                         IsReadOnly="True" Margin="8,10,8,8"
                         Background="{DynamicResource LogBrush}" 
                         Foreground="{DynamicResource LogTextBrush}" 
                         FontFamily="Consolas" FontSize="11" 
                         VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                         TextChanged="LogTextBox_TextChanged"/>
            </Grid>
        </Expander>
    </Grid>
</Window>
